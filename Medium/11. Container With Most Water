class Solution {
    fun maxArea(height: IntArray): Int {
      var maxArea = 0
        var left = 0 
        var right = height.size -1
        while(left<right){
            val area = (right - left)*min(height[left],height[right])
            maxArea = max(maxArea,area)
            if(height[left]<height[right]) left++
            else right--
        }
        return maxArea
    }
}
